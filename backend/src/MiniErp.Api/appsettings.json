{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mini_erp;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "MiniErp",
    "Audience": "MiniErp.Client",
    "Key": "super-secret-development-key-change-me",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "MiniErp.Api"
    }
  }
}
