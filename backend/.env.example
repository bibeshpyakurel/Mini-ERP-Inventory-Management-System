ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=mini_erp;Username=postgres;Password=postgres
CORS_ALLOWED_ORIGIN=http://localhost:5173
Jwt__Issuer=MiniErp
Jwt__Audience=MiniErp.Client
Jwt__Key=replace-with-a-strong-random-secret-at-least-32-chars
POSTGRES_DB=mini_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_PORT=5432
BACKEND_PORT=5000